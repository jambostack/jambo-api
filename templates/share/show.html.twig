<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="robots" content="noindex, nofollow">
    <title>{{ collection }} — Aperçu partagé · Jambo</title>
    <style>
        body { font-family: 'DM Sans', system-ui, sans-serif; max-width: 760px; margin: 40px auto; padding: 0 20px; color: #1a1a1a; line-height: 1.6; }
        .badge { display: inline-block; background: #eef2ff; color: #4338ca; font-size: 12px; padding: 2px 10px; border-radius: 999px; }
        h1 { font-size: 1.4rem; margin: 12px 0 4px; }
        .meta { color: #6b7280; font-size: 13px; margin-bottom: 24px; }
        dl { display: grid; grid-template-columns: 200px 1fr; gap: 8px 16px; }
        dt { font-weight: 600; color: #374151; }
        dd { margin: 0; }
        footer { margin-top: 40px; color: #9ca3af; font-size: 12px; border-top: 1px solid #e5e7eb; padding-top: 12px; }
        img { max-width: 100%; height: auto; border-radius: 6px; }
    </style>
</head>
<body>
    <span class="badge">Aperçu partagé</span>
    <h1>{{ collection }}</h1>
    <p class="meta">Statut : {{ entry.status }}</p>
    <dl>
        {% for key, value in entry %}
            {% if key not in ['id', 'uuid', 'collection', 'created_at', 'updated_at', 'deleted_at', 'creator', 'updater', 'assigned_to'] and value is not null %}
                <dt>{{ key }}</dt>
                <dd>
                    {% if value is iterable %}
                        {{ value|json_encode }}
                    {% else %}
                        {{ value }}
                    {% endif %}
                </dd>
            {% endif %}
        {% endfor %}
    </dl>
    <footer>Propulsé par Jambo</footer>
</body>
</html>
