# ─── Application ──────────────────────────────────────────────────────────────
APP_ENV=dev
APP_SECRET=change-me-generate-with-openssl-rand-hex-32
APP_NAME="JamboApi"
APP_HOSTNAME=api.jambostack.site
DEFAULT_URI=https://api.jambostack.site
APP_SHARE_DIR=var/share

# ─── Database ─────────────────────────────────────────────────────────────────
# Supported: mysql, postgresql, sqlite
DATABASE_URL="mysql://jprud67_jamboapi:Benin@667229@127.0.0.1:3306/jprud67_jamboapi?serverVersion=8.0.32&charset=utf8mb4"

# ─── Messenger (async queue) ───────────────────────────────────────────────────
MESSENGER_TRANSPORT_DSN=doctrine://default?auto_setup=0

# ─── Mailer ───────────────────────────────────────────────────────────────────
# Disable: null://null
# SMTP:    smtp://user:pass@smtp.example.com:587
MAILER_DSN=smtp://noreply%40jambostack.site:Benin%7C229@mail.jambostack.site:465?encryption=ssl
###> symfony/mercure-bundle ###
# See https://symfony.com/doc/current/mercure.html#configuration
# The URL of the Mercure hub, used by the app to publish updates (can be a local URL)
MERCURE_URL=http://127.0.0.1:8080/.well-known/mercure
# The public URL of the Mercure hub, used by the browser to connect
MERCURE_PUBLIC_URL=https://api.jambostack.site/.well-known/mercure
# The secret used to sign the JWTs
MERCURE_JWT_SECRET=b5ae0064ba86b70d23367fdb5a8a4277011e65c99107de05a52df03f7fec40a1
###< symfony/mercure-bundle ###

# ─── Meilisearch (full-text search) ───────────────────────────────────────────
MEILISEARCH_HOST=http://localhost:7700
MEILISEARCH_KEY=

# ─── Webhooks ─────────────────────────────────────────────────────────────────
APP_WEBHOOK_SECRET_KEY=change-me-random-secret

# ─── AI Providers (configured via Admin → Settings → AI Studio) ───────────────
# You can also set keys here as fallback environment variables.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
DEEPSEEK_API_KEY=
