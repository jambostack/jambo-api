{
  "name": "@jambostack/live-preview",
  "version": "1.0.0-alpha.1",
  "description": "SDK frontend for Jambo CMS Live Preview — iframe postMessage bridge, visual editing, and Next.js hook",
  "license": "MIT",
  "type": "module",
  "main": "./dist/core/index.js",
  "types": "./dist/core/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/core/index.d.ts",
      "default": "./dist/core/index.js"
    },
    "./core": {
      "types": "./dist/core/index.d.ts",
      "default": "./dist/core/index.js"
    },
    "./next": {
      "types": "./dist/next/index.d.ts",
      "default": "./dist/next/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc --project tsconfig.json",
    "prepublishOnly": "npm run build"
  },
  "keywords": ["jambo", "cms", "live-preview", "headless", "visual-editing"],
  "repository": {
    "type": "git",
    "url": "https://github.com/jambostack/jambo-api",
    "directory": "packages/live-preview"
  },
  "peerDependencies": {
    "react": ">=18.0.0"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    }
  }
}
